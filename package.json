{
  "name": "apex-timezones",
  "productName": "ApexTimeZones",
  "version": "2.3.1",
  "description": "System-tray world clock with 3D globe, verified sports schedules, and dual-zone tune-in times",
  "main": "electron/main.js",
  "author": "ApexTimeZones",
  "license": "MIT",
  "scripts": {
    "bundle": "node scripts/build-renderer.mjs",
    "bundle:prod": "node scripts/build-renderer.mjs --prod",
    "prestart": "npm run bundle",
    "start": "electron .",
    "predev": "npm run bundle",
    "dev": "electron . --dev",
    "test": "node --test tests/timeMath.test.mjs tests/sports.test.mjs",
    "prebuild:win": "npm run bundle:prod",
    "pack": "npm run bundle:prod && electron-builder --win portable",
    "dist": "npm run bundle:prod && electron-builder --win",
    "build:win": "electron-builder --win nsis portable",
    "release:prep": "node scripts/release-prep.mjs",
    "sports:build": "node scripts/build-sports-data.mjs",
    "sports:audit": "node scripts/sports-audit.mjs",
    "sports:freshness": "node scripts/check-data-freshness.mjs",
    "smoke": "node scripts/smoke-checklist.mjs"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.1",
    "three": "^0.171.0"
  },
  "build": {
    "appId": "com.apextimezones.app",
    "productName": "ApexTimeZones",
    "copyright": "Copyright © ApexTimeZones",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "assets/**/*",
      "public/**/*",
      "package.json",
      "!src/js/**/*.map",
      "!src/js/app.bundle.js.map",
      "!**/*.map"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ApexTimeZones",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
